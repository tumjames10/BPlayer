<Window x:Class="BPlayer.Windows.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Width="380" Height="290" Background="Transparent">
    <Border CornerRadius="12" Background="#141420" BorderBrush="#2a2a4e"
            BorderThickness="1" Margin="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.5" ShadowDepth="4" Color="Black" />
        </Border.Effect>
        <Grid Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="AppTitle" FontSize="20" FontWeight="Bold"
                       Foreground="#e94560" Margin="0,0,0,4" />

            <TextBlock Grid.Row="1" x:Name="VersionText" FontSize="13"
                       Foreground="#9ca3af" Margin="0,0,0,12" />

            <StackPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock FontSize="13" Foreground="#f3f4f6" Margin="0,0,0,4">
                    <Run Text="Built on" />
                    <Run Text="VideoLAN.LibVLC" FontWeight="SemiBold" Foreground="#3b82f6" />
                    <Run Text="for playback" />
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#f3f4f6">
                    <Run Text="GitHub:" />
                    <Hyperlink NavigateUri="https://github.com/tumjames10"
                               RequestNavigate="OnLinkClick"
                               Foreground="#60a5fa" TextDecorations="None">
                        github.com/tumjames10
                    </Hyperlink>
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#f3f4f6" Margin="0,4,0,0">
                    <Run Text="Contact:" />
                    <Hyperlink NavigateUri="mailto:bbtumulak@gmail.com"
                               RequestNavigate="OnLinkClick"
                               Foreground="#60a5fa" TextDecorations="None">
                        bbtumulak@gmail.com
                    </Hyperlink>
                </TextBlock>
                <TextBlock FontSize="13" Foreground="#f3f4f6" Margin="0,4,0,0">
                    <Hyperlink NavigateUri="PrivacyPolicy.html"
                               RequestNavigate="OnLinkClick"
                               Foreground="#60a5fa" TextDecorations="None">
                        Privacy Policy
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <Button Grid.Row="3" Content="Close" Width="90" Height="34"
                    HorizontalAlignment="Right" Cursor="Hand" FontSize="13"
                    Background="#e94560" Foreground="White"
                    BorderThickness="0" Click="OnCloseClick" />
        </Grid>
    </Border>
</Window>
