<Window x:Class="BPlayer.Windows.PlaylistPicker"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Width="360" Height="420" Background="Transparent"
        MinHeight="280" MaxHeight="520">
    <Border CornerRadius="14" Background="#141420" BorderBrush="#2a2a4e"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" Opacity="0.5" ShadowDepth="6" Color="Black" />
        </Border.Effect>
        <Grid Margin="20,18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Add to Playlist"
                           FontSize="17" FontWeight="Bold" Foreground="#f3f4f6"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1" x:Name="CloseBtn" Text="×"
                           FontSize="20" Foreground="#6b7280" Cursor="Hand"
                           MouseLeftButtonDown="OnCloseClick"
                           VerticalAlignment="Center" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Margin="0,0,0,8" CanContentScroll="False">
                <StackPanel x:Name="PlaylistItems" />
            </ScrollViewer>

            <Border Grid.Row="2" Background="#1a1a2e" CornerRadius="8"
                    Padding="0" Cursor="Hand" Height="40"
                    MouseLeftButtonDown="OnNewPlaylistClick"
                    Margin="0,4,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="+" FontSize="18"
                               FontWeight="Bold" Foreground="#e94560"
                               Margin="14,0,10,0" VerticalAlignment="Center" />
                    <TextBlock Grid.Column="1" Text="New Playlist"
                               FontSize="13" Foreground="#e94560"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

            <Border Grid.Row="3" CornerRadius="8" BorderThickness="1"
                    BorderBrush="#2a2a4e" Background="Transparent" Height="36">
                <Button x:Name="CancelBtn" Content="Cancel"
                        Click="OnCancelClick"
                        Background="Transparent" Foreground="#6b7280"
                        BorderThickness="0" FontSize="13" Cursor="Hand" />
            </Border>
        </Grid>
    </Border>
</Window>
