<Window x:Class="BPlayer.Windows.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="NoResize" WindowStartupLocation="CenterOwner"
        Width="380" Height="190" Background="Transparent">
    <Border CornerRadius="12" Background="#141420" BorderBrush="#2a2a4e"
            BorderThickness="1" Margin="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" Opacity="0.5" ShadowDepth="4" Color="Black" />
        </Border.Effect>
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" x:Name="DialogTitle" Text="Rename"
                       FontSize="16" FontWeight="Bold" Foreground="#f3f4f6"
                       Margin="0,0,0,16" />

            <TextBox Grid.Row="1" x:Name="InputBox" FontSize="14"
                     Padding="12,10" Background="#1a1a2e" Foreground="#f3f4f6"
                     BorderBrush="#2a2a4e" BorderThickness="1"
                     CaretBrush="#e94560" SelectionBrush="#e94560" />

            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button x:Name="CancelBtn" Content="Cancel" Width="90" Height="34"
                        Cursor="Hand" FontSize="13" Margin="0,0,8,0"
                        Background="#1e1e30" Foreground="#f3f4f6"
                        BorderThickness="0" Click="OnCancelClick" />
                <Button x:Name="ConfirmBtn" Content="Save" Width="90" Height="34"
                        Cursor="Hand" FontSize="13" FontWeight="SemiBold"
                        Background="#e94560" Foreground="White"
                        BorderThickness="0" Click="OnConfirmClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
