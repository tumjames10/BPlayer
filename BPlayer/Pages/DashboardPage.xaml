<Page x:Class="BPlayer.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:conv="clr-namespace:BPlayer.Converters"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="1200"
      Title="Dashboard">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />

        <!-- Spinner rotation animation -->
        <Storyboard x:Key="SpinnerAnim" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="LoadingSpinner"
                             Storyboard.TargetProperty="RenderTransform.Angle"
                             From="0" To="360" Duration="0:0:1.2" />
        </Storyboard>

        <Style x:Key="PosterCard" TargetType="Border">
            <Setter Property="Width" Value="240" />
            <Setter Property="Height" Value="360" />
            <Setter Property="Margin" Value="10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" Opacity="0.35" ShadowDepth="4" Color="Black" />
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1.08" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1.08" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Effect.BlurRadius"
                                                 To="24" Duration="0:0:0.2" />
                                <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity"
                                                 To="0.6" Duration="0:0:0.2" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                 To="1.0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                 To="1.0" Duration="0:0:0.3">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseOut" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="Effect.BlurRadius"
                                                 To="14" Duration="0:0:0.3" />
                                <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity"
                                                 To="0.35" Duration="0:0:0.3" />
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewPlayBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="0,10" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewAddBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="0,10" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SidebarItem" TargetType="Border">
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource ButtonBgBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ContextMenu style -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background" Value="{DynamicResource BgSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderColorBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{DynamicResource BgSurfaceBrush}"
                                BorderBrush="{DynamicResource BorderColorBrush}"
                                BorderThickness="1" CornerRadius="12" Padding="4">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10" Opacity="0.35" ShadowDepth="4" Color="Black" />
                            </Border.Effect>
                            <ItemsPresenter />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="6"
                                Margin="2,1" MinHeight="34">
                            <ContentPresenter ContentSource="Header"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{DynamicResource BgDarkBrush}" KeyDown="OnPageKeyDown">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition x:Name="MainContentCol" Width="*" MinWidth="400" />
            <ColumnDefinition x:Name="PreviewCol" Width="0" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.RowSpan="2" Width="220" Background="{DynamicResource BgSurfaceBrush}" Padding="0,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- App logo -->
                <Border Grid.Row="0" Padding="20,20,20,16">
                    <TextBlock Text="BPlayer" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource AccentBrush}" />
                </Border>

                <!-- Library section -->
                <StackPanel Grid.Row="1">
                    <TextBlock Text="LIBRARY" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="20,0,20,8" />

                    <Border Style="{StaticResource SidebarItem}"
                            x:Name="AllVideosBtn" MouseLeftButtonDown="OnAllVideosClick"
                            Background="{DynamicResource ButtonBgBrush}" Tag="__all__">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🎬" FontSize="14" Margin="0,0,10,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="All Videos" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                       FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Folders section -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Background="Transparent">
                    <StackPanel Margin="0,12,0,0">
                        <TextBlock Text="FOLDERS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="20,0,20,8" />
                        <ItemsControl x:Name="FolderListSidebar">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SidebarItem}"
                                            MouseLeftButtonDown="OnFolderClick"
                                            Tag="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📁" FontSize="12" Margin="0,0,10,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Text="{Binding}"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="13" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Playlists section -->
                <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto"
                              Margin="0,12,0,0" Background="Transparent">
                    <StackPanel>
                        <Grid Margin="20,0,20,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="PLAYLISTS" FontSize="10"
                                       FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" x:Name="ImportPlaylistsBtn"
                                       Text="⇧" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Cursor="Hand" Margin="4,0"
                                       MouseLeftButtonDown="OnImportPlaylistsClick"
                                       ToolTip="Import playlists (M3U)" />
                            <TextBlock Grid.Column="2" x:Name="ExportPlaylistsBtn"
                                       Text="⇩" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Cursor="Hand" Margin="4,0"
                                       MouseLeftButtonDown="OnExportPlaylistsClick"
                                       ToolTip="Export playlists (M3U)" />
                            <TextBlock Grid.Column="3" x:Name="NewPlaylistBtn"
                                       Text="+" FontSize="18" Foreground="{DynamicResource AccentBrush}"
                                       Cursor="Hand" FontWeight="Bold"
                                       MouseLeftButtonDown="OnNewPlaylistClick" />
                        </Grid>

                        <ItemsControl x:Name="PlaylistList" AllowDrop="True"
                                      Drop="OnPlaylistDrop"
                                      PreviewMouseMove="OnPlaylistPreviewMouseMove"
                                      PreviewMouseLeftButtonDown="OnPlaylistPreviewMouseDown">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                     <Border Style="{StaticResource SidebarItem}"
                                             MouseLeftButtonDown="OnPlaylistClick"
                                             MouseRightButtonDown="OnPlaylistRightClick"
                                             Tag="{Binding Name}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="▶" FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                                           Margin="0,0,10,0" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="13" VerticalAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="×" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="14" Cursor="Hand"
                                                       MouseLeftButtonDown="OnDeletePlaylistClick"
                                                       Tag="{Binding Name}" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="20,12,20,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="3" Height="14" CornerRadius="2"
                                    Background="{DynamicResource AccentBrush}" Margin="0,0,10,0"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1" Text="COLLECTIONS" FontSize="10"
                                       FontWeight="Bold" Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" x:Name="CollectionsInfoBtn"
                                       Text="ⓘ" FontSize="14" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Cursor="Hand" VerticalAlignment="Center" Margin="6,0,6,0"
                                       MouseLeftButtonDown="OnCollectionsInfoClick" />
                            <TextBlock Grid.Column="3" x:Name="DetectCollectionsBtn"
                                       Text="⟳" FontSize="16" Foreground="{DynamicResource AccentBrush}"
                                       Cursor="Hand" FontWeight="Bold"
                                       MouseLeftButtonDown="OnDetectCollectionsClick"
                                       ToolTip="Auto-detect collections" />
                        </Grid>

                        <!-- Collections info popup -->
                        <Border x:Name="CollectionsInfoPopup" Visibility="Collapsed"
                                Background="{DynamicResource BgSurfaceBrush}" CornerRadius="10"
                                BorderBrush="{DynamicResource BorderColorBrush}" BorderThickness="1"
                                Margin="20,4,16,0" Padding="14,12">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="16" Opacity="0.3" ShadowDepth="4" Color="Black" />
                            </Border.Effect>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="📚" FontSize="14" Margin="0,0,8,0" />
                                    <TextBlock Text="What are Collections?" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Collections group related videos automatically based on file names."
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,0,0,6" />
                                <TextBlock Text="• TV shows: &quot;Show S01E01&quot; → &quot;Show&quot;"
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="• Multi-part: &quot;Title Part 1&quot; → &quot;Title&quot;"
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="Click ⟳ to scan for new collections."
                                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>

                        <ItemsControl x:Name="CollectionsSidebar" Margin="0,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SidebarItem}"
                                            MouseLeftButtonDown="OnCollectionClick"
                                            Tag="{Binding Name}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="📚" FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                                       Margin="0,0,10,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                       FontSize="13" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar footer -->
                <StackPanel Grid.Row="4" Margin="0,8,0,12">
                    <Border Height="1" Background="{DynamicResource BorderColorBrush}" Margin="16,0,16,8" />
                    <Border Style="{StaticResource SidebarItem}" MouseLeftButtonDown="OnAboutClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ℹ" FontSize="12" Margin="0,0,10,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="About BPlayer" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SidebarItem}" MouseLeftButtonDown="OnSendFeedbackClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉" FontSize="12" Margin="0,0,10,0" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="Send Feedback" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Top bar (spans main content + preview columns) -->
        <Border Grid.Column="1" Grid.ColumnSpan="2" Grid.Row="0" Padding="24,16" Background="{DynamicResource BgDarkBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="280" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" x:Name="ViewTitle"
                           Text="All Videos" FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center" />

                <Border Grid.Column="1" Background="{DynamicResource BgCardBrush}"
                        BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1" CornerRadius="8" Margin="16,0,0,0"
                        VerticalAlignment="Center" Height="34">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchBox" Grid.Column="0"
                                 Background="Transparent" Foreground="{DynamicResource TextPrimaryBrush}"
                                 BorderThickness="0" Padding="10,0" VerticalAlignment="Center"
                                 FontSize="14" TextChanged="OnSearchTextChanged"
                                 CaretBrush="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Grid.Column="1" Text="🔍" FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,10,0" />
                    </Grid>
                </Border>

                <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,10,0"
                            VerticalAlignment="Center">
                    <TextBlock Text="Sort:" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <Border x:Name="SortBtn" Background="{DynamicResource BgCardBrush}"
                            BorderBrush="{DynamicResource BorderColorBrush}"
                            BorderThickness="1" CornerRadius="8" Cursor="Hand" MinWidth="90"
                            MouseLeftButtonDown="OnSortClick" Padding="10,6">
                        <TextBlock x:Name="SortLabel" Text="Name" Foreground="{DynamicResource TextPrimaryBrush}"
                                   FontSize="12" VerticalAlignment="Center" />
                    </Border>
                    <Border x:Name="SortDirBtn" Background="{DynamicResource BgCardBrush}"
                            BorderBrush="{DynamicResource BorderColorBrush}"
                            BorderThickness="1" CornerRadius="8" Cursor="Hand"
                            MouseLeftButtonDown="OnSortDirClick" Padding="8,6" Margin="4,0,0,0">
                        <TextBlock x:Name="SortDirLabel" Text="↑" Foreground="{DynamicResource AccentBrush}"
                                   FontSize="14" FontWeight="Bold" VerticalAlignment="Center" />
                    </Border>
                </StackPanel>

                <Border Grid.Column="5" Background="{DynamicResource ButtonBgBrush}" CornerRadius="8" Padding="0">
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="RefreshBtn" Click="OnRefreshClick"
                                Style="{StaticResource ModernBtn}"
                                Padding="10,7" Content="↻ Refresh" />
                        <Button x:Name="SettingsBtn" Click="OnSettingsClick"
                                Style="{StaticResource ModernBtn}"
                                Padding="12,7" Content="⚙ Settings" />
                        <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="8" Padding="0" Margin="6,0,0,0">
                            <ComboBox x:Name="ThemeSwitcher" Width="100" Height="30"
                                      Foreground="{DynamicResource TextPrimaryBrush}"
                                      Background="{DynamicResource ButtonBgBrush}"
                                      BorderThickness="0"
                                      SelectionChanged="OnThemeSelected"
                                      FontSize="12" />
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main content -->
        <ScrollViewer Grid.Column="1" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                       Background="{DynamicResource BgDarkBrush}"
                       x:Name="OuterScrollViewer"
                       PreviewMouseWheel="OnOuterPreviewMouseWheel">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- View toggle bar -->
            <Border Grid.Row="0" Background="{DynamicResource BgDarkBrush}" Padding="24,0,24,4">
                <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="8" Padding="6,4" HorizontalAlignment="Left">
                    <Button x:Name="ViewToggleBtn" Click="OnViewToggleClick"
                            Style="{StaticResource ModernBtn}"
                            Padding="10,6" Content="☰ List"
                            FontSize="12" />
                </Border>
            </Border>

            <!-- Playlist actions bar -->
            <StackPanel Grid.Row="1" x:Name="SidebarPlaylistActions" Visibility="Collapsed"
                        Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="6"
                        Padding="0" Cursor="Hand" Margin="0,0,6,0">
                    <Button x:Name="AddPlaylistBarBtn" Click="OnAddPlaylistFromBarClick"
                            Style="{StaticResource ModernBtn}" Padding="12,6"
                            Content="+ New Playlist" />
                </Border>
                <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="6"
                        Padding="0" Cursor="Hand" Margin="0,0,6,0">
                    <Button x:Name="RenamePlaylistBarBtn" Click="OnRenamePlaylistClick"
                            Style="{StaticResource ModernBtn}" Padding="12,6"
                            Content="✏ Rename" />
                </Border>
                <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="6"
                        Padding="0" Cursor="Hand" Margin="0,0,6,0">
                    <Button x:Name="DuplicatePlaylistBarBtn" Click="OnDuplicatePlaylistClick"
                            Style="{StaticResource ModernBtn}" Padding="12,6"
                            Content="⧉ Duplicate" />
                </Border>
                <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="6"
                        Padding="0" Cursor="Hand">
                    <Button x:Name="DeletePlaylistBarBtn" Click="OnDeletePlaylistFromBarClick"
                            Style="{StaticResource ModernBtn}" Padding="12,6"
                            Foreground="#ef4444" Content="× Delete" />
                </Border>
            </StackPanel>

            <!-- Scan progress bar -->
            <Border x:Name="ProgressBar" Grid.Row="2" Height="3" Background="{DynamicResource BgCardBrush}"
                    Visibility="Collapsed" VerticalAlignment="Top">
                <Border x:Name="ProgressFill" Width="0" Background="{DynamicResource AccentBrush}"
                        HorizontalAlignment="Left" />
            </Border>

            <!-- Continue Watching -->
            <Border Grid.Row="3" x:Name="ContinueWatchingSection" Visibility="Collapsed"
                    Background="{DynamicResource BgDarkBrush}" Padding="24,8,24,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Continue Watching" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Hidden"
                                      x:Name="ContinueWatchingScroll">
                            <StackPanel x:Name="ContinueWatchingPanel" Orientation="Horizontal" />
                        </ScrollViewer>
                        <Border x:Name="CWScrollLeftBtn" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Width="45" Height="45" CornerRadius="23"
                                Background="#CC1e1e1e" Cursor="Hand" Visibility="Collapsed"
                                MouseLeftButtonDown="OnCWScrollLeft" Padding="0">
                            <TextBlock Text="◀" FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border x:Name="CWScrollRightBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="45" Height="45" CornerRadius="23"
                                Background="#CC1e1e1e" Cursor="Hand" Visibility="Collapsed"
                                MouseLeftButtonDown="OnCWScrollRight" Padding="0">
                            <TextBlock Text="▶" FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Recently Added -->
            <Border Grid.Row="4" x:Name="RecentSection" Visibility="Collapsed"
                    Background="{DynamicResource BgDarkBrush}" Padding="24,8,24,4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Recently Added" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,6" />
                    <Grid Grid.Row="1">
                        <ScrollViewer VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Hidden"
                                      x:Name="RecentScroll">
                            <StackPanel x:Name="RecentPanel" Orientation="Horizontal" />
                        </ScrollViewer>
                        <Border x:Name="RecentScrollLeftBtn" HorizontalAlignment="Left" VerticalAlignment="Center"
                                Width="45" Height="45" CornerRadius="23"
                                Background="#CC1e1e1e" Cursor="Hand" Visibility="Collapsed"
                                MouseLeftButtonDown="OnRecentScrollLeft" Padding="0">
                            <TextBlock Text="◀" FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <Border x:Name="RecentScrollRightBtn" HorizontalAlignment="Right" VerticalAlignment="Center"
                                Width="45" Height="45" CornerRadius="23"
                                Background="#CC1e1e1e" Cursor="Hand" Visibility="Collapsed"
                                MouseLeftButtonDown="OnRecentScrollRight" Padding="0">
                            <TextBlock Text="▶" FontSize="18" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <!-- Video grid -->
            <ItemsControl Grid.Row="5" x:Name="VideosList" ItemsSource="{Binding}"
                          Padding="24,4,24,20" Background="{DynamicResource BgDarkBrush}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource PosterCard}"
                                    MouseLeftButtonDown="OnTileClick"
                                    MouseRightButtonDown="OnTileRightClick"
                                    Tag="{Binding FilePath}"
                                    Background="{Binding PlaceholderColor}">
                                <Grid>
                                    <TextBlock Text="{Binding Initial}"
                                               FontSize="56" FontWeight="Light"
                                                Foreground="White" Opacity="0.35"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />

                                    <Image Source="{Binding ThumbnailUrl}"
                                           Stretch="UniformToFill"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding HasThumbnail, Converter={StaticResource BoolVis}}" />

                                    <Border VerticalAlignment="Bottom" Height="65">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#00000000" Offset="0" />
                                                <GradientStop Color="#DD000000" Offset="1" />
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <StackPanel Margin="10,18,10,8" VerticalAlignment="Bottom">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="White" FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding DisplayInfo}"
                                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="10"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>

                                    <Border VerticalAlignment="Top" HorizontalAlignment="Right"
                                            Background="#22c55e" CornerRadius="10" Padding="6,2" Margin="0,8,8,0"
                                            Visibility="{Binding IsWatched, Converter={StaticResource BoolVis}}"
                                            Opacity="0.9">
                                        <TextBlock Text="✓" FontSize="11" FontWeight="Bold" Foreground="White" />
                                    </Border>

                                    <Border Visibility="{Binding IsSelected, Converter={StaticResource BoolVis}}"
                                            BorderBrush="{DynamicResource AccentBrush}" BorderThickness="3"
                                            CornerRadius="12" Background="#30e94560" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            <!-- List view (hidden by default) -->
            <ItemsControl Grid.Row="5" x:Name="VideosListView" ItemsSource="{Binding}"
                          Visibility="Collapsed" Background="{DynamicResource BgDarkBrush}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{DynamicResource BorderColorBrush}" BorderThickness="0,0,0,1"
                                    Padding="8,6" MouseLeftButtonDown="OnTileClick"
                                    Tag="{Binding FilePath}" Cursor="Hand">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="48" Height="48" CornerRadius="6"
                                            Background="{Binding PlaceholderColor}" Margin="0,0,10,0" ClipToBounds="True">
                                        <Grid>
                                            <TextBlock Text="{Binding Initial}" FontSize="20" FontWeight="Light"
                                                       Foreground="White" Opacity="0.5"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill"
                                                   Visibility="{Binding HasThumbnail, Converter={StaticResource BoolVis}}" />
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding DisplayInfo}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="11" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding Folder}"
                                               Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11"
                                               VerticalAlignment="Center" Margin="10,0" />
                                    <Border Grid.Column="3" VerticalAlignment="Center"
                                            Background="#22c55e" CornerRadius="8" Padding="6,2"
                                            Visibility="{Binding IsWatched, Converter={StaticResource BoolVis}}"
                                            Opacity="0.8">
                                        <TextBlock Text="✓" FontSize="10" FontWeight="Bold" Foreground="White" />
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            <Border Grid.Row="1" Grid.RowSpan="5" x:Name="EmptyOverlay" Visibility="Collapsed"
                    Background="{DynamicResource BgDarkBrush}">
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="20"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Padding="48,44" BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1" MaxWidth="440">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" Opacity="0.25" ShadowDepth="6" Color="Black" />
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="🎬" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,12" />
                        <TextBlock Text="It's all quiet here"
                                   FontSize="22" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="Add some video folders to get started"
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,6,0,24"
                                   TextWrapping="Wrap" TextAlignment="Center" />
                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="10"
                                Padding="0" Cursor="Hand" HorizontalAlignment="Center"
                                x:Name="EmptyAddFoldersBtn"
                                MouseLeftButtonDown="OnEmptyAddFoldersClick">
                            <StackPanel Orientation="Horizontal" Margin="20,10">
                                <TextBlock Text="+" FontSize="18" FontWeight="Bold"
                                           Foreground="White" Margin="0,0,8,0" />
                                <TextBlock Text="Add Folders"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="White" />
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="8"
                                Padding="14,8" Margin="0,14,0,0" HorizontalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="or press" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,6,0" />
                                <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="Ctrl+S" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}" />
                                </Border>
                                <TextBlock Text="to open settings" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="6,0,0,0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>
            </Border>

            <!-- Loading overlay -->
            <Border Grid.Row="1" Grid.RowSpan="5" x:Name="LoadingOverlay" Visibility="Collapsed"
                    Background="#99000000">
                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="16"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Padding="40,36" BorderBrush="{DynamicResource BorderColorBrush}"
                        BorderThickness="1" MinWidth="280">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="32" Opacity="0.4" ShadowDepth="8" Color="Black" />
                    </Border.Effect>
                    <StackPanel HorizontalAlignment="Center">
                        <!-- Spinner ring -->
                        <Border x:Name="LoadingSpinner" Width="40" Height="40"
                                HorizontalAlignment="Center" Margin="0,0,0,16">
                            <Border.RenderTransform>
                                <RotateTransform CenterX="20" CenterY="20" />
                            </Border.RenderTransform>
                            <Grid>
                                <Border Width="40" Height="40" CornerRadius="20"
                                        BorderThickness="3" BorderBrush="{DynamicResource BorderColorBrush}"
                                        Opacity="0.3" />
                                <Border Width="40" Height="40" CornerRadius="20"
                                        BorderThickness="3"
                                        BorderBrush="{DynamicResource AccentBrush}">
                                    <Border.OpacityMask>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="White" Offset="0.35" />
                                            <GradientStop Color="Transparent" Offset="0.65" />
                                        </LinearGradientBrush>
                                    </Border.OpacityMask>
                                </Border>
                            </Grid>
                        </Border>
                        <TextBlock x:Name="LoadingTitle" Text="Scanning folders"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock x:Name="LoadingSubtitle" Text="Looking for video files..."
                                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
        </ScrollViewer>

        <!-- Right: preview panel -->
        <Border Grid.Column="2" Grid.Row="1" x:Name="PreviewPanel"
                Visibility="Collapsed">
            <Grid>
                <Rectangle x:Name="PreviewGradient" />

                <Rectangle Fill="#18181a" Opacity="0.25" />

                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24,16">
                    <StackPanel>

                        <!-- Poster -->
                        <Border x:Name="PreviewPosterBorder" Height="320"
                                CornerRadius="14" ClipToBounds="True"
                                Background="{DynamicResource BgCardBrush}" Margin="0,0,0,14"
                                HorizontalAlignment="Center">
                            <Grid>
                                <Border x:Name="PreviewBg" Background="{DynamicResource BgCardBrush}">
                                    <TextBlock x:Name="PreviewInitial"
                                               FontSize="54" FontWeight="Light"
                                               Foreground="White" Opacity="0.12"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <Image x:Name="PreviewThumb" Stretch="UniformToFill" />
                            </Grid>
                        </Border>

                        <!-- Title -->
                        <TextBlock x:Name="PreviewTitle"
                                   Foreground="White" FontSize="18" FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,4" />

                        <!-- Year + Rating -->
                        <TextBlock x:Name="PreviewMeta"
                                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,0,4" />

                        <!-- Rating badge -->
                        <Border x:Name="PreviewRatingBadge" Background="{DynamicResource AccentBrush}"
                                CornerRadius="6" Padding="8,4" Margin="0,0,0,16"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="PreviewRating"
                                       Foreground="White" FontSize="12"
                                       FontWeight="SemiBold" />
                        </Border>

                        <!-- Buttons -->
                        <Border x:Name="PreviewResumeBorder" Background="{DynamicResource AccentBrush}"
                                CornerRadius="10" Padding="0" Cursor="Hand" Margin="0,0,0,10"
                                HorizontalAlignment="Stretch" Visibility="Collapsed">
                            <Button x:Name="PreviewResumeBtn" Click="OnPreviewResume"
                                    Style="{StaticResource PreviewPlayBtn}"
                                    Foreground="White" Content="▶  Resume" />
                        </Border>

                        <Border x:Name="PreviewPlayFromStartBorder" Background="{DynamicResource BgCardBrush}"
                                CornerRadius="10" Padding="0" Cursor="Hand" Margin="0,0,0,10"
                                HorizontalAlignment="Stretch" Visibility="Collapsed">
                            <Button x:Name="PreviewPlayFromStartBtn" Click="OnPreviewPlayFromStart"
                                    Style="{StaticResource PreviewPlayBtn}"
                                    Content="↺  Play from Beginning" />
                        </Border>

                        <Border x:Name="PreviewPlayBorder" Background="{DynamicResource BgCardBrush}"
                                CornerRadius="10" Padding="0" Cursor="Hand" Margin="0,0,0,10"
                                HorizontalAlignment="Stretch">
                            <Button x:Name="PreviewPlayBtn" Click="OnPreviewPlay"
                                    Style="{StaticResource PreviewPlayBtn}"
                                    Content="▶  Play" />
                        </Border>

                        <Border Background="{DynamicResource ButtonBgBrush}" CornerRadius="10"
                                Padding="0" Cursor="Hand" Margin="0,0,0,10">
                            <Button x:Name="AddToPlaylistBtn" Click="OnAddToPlaylist"
                                    Style="{StaticResource PreviewAddBtn}"
                                    Content="+ Add to Playlist" />
                        </Border>

                        <!-- Video Info -->
                        <Border x:Name="VideoInfoSection" Background="{DynamicResource BgCardBrush}"
                                CornerRadius="10" Padding="14" Margin="0,0,0,10"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="File Info" FontSize="12" FontWeight="Bold"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,8" />
                                <TextBlock x:Name="InfoFileSize" FontSize="11"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,3" />
                                <TextBlock x:Name="InfoResolution" FontSize="11"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,3" />
                                <TextBlock x:Name="InfoCodec" FontSize="11"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"
                                           Margin="0,0,0,3" />
                                <TextBlock x:Name="InfoBitrate" FontSize="11"
                                           Foreground="{DynamicResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
