<Window x:Class="BPlayer.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="640" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgDarkBrush}"
        ShowInTaskbar="False"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title bar -->
        <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Settings"
                           FontSize="22" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           VerticalAlignment="Center" />
                <Border Grid.Column="1" HorizontalAlignment="Right"
                        Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="10,4"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="ActiveTabLabel" Text="General"
                               Foreground="White" FontSize="11" FontWeight="SemiBold" />
                </Border>
            </Grid>
        </Border>

        <!-- Tab bar -->
        <Border Grid.Row="1" Margin="24,16,24,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Tab buttons -->
                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}"
                        CornerRadius="10" Padding="3,3,3,0" Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" x:Name="GeneralTab" CornerRadius="8,8,0,0"
                                Background="{DynamicResource AccentBrush}" Padding="12,8"
                                Cursor="Hand" MouseLeftButtonDown="OnGeneralTabClick">
                            <TextBlock Text="⚙  General" Foreground="White"
                                       FontSize="13" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Border Grid.Column="1" x:Name="ThemesTab" CornerRadius="8,8,0,0"
                                Background="Transparent" Padding="12,8"
                                Cursor="Hand" MouseLeftButtonDown="OnThemesTabClick">
                            <TextBlock Text="🎨  Themes" Foreground="{DynamicResource TextPrimaryBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </Border>
                    </Grid>
                </Border>

                <!-- GENERAL TAB -->
                <ScrollViewer Grid.Row="1" x:Name="GeneralContent"
                              VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">
                    <StackPanel>

                        <!-- ═══ VIDEO FOLDERS ═══ -->
                        <Border Background="{DynamicResource BgSurfaceBrush}" CornerRadius="10" Padding="0" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}"
                                        Padding="14,10" CornerRadius="10,10,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="3" Height="18"
                                                   Fill="{DynamicResource AccentBrush}" RadiusX="1.5" RadiusY="1.5"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Video Folders"
                                                   FontWeight="Bold" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Click="OnAddFolders" Content="+ Add Folders"
                                                Style="{StaticResource AccentBtn}" Padding="10,4"
                                                FontSize="12" Margin="0,0,6,0" />
                                        <Button Grid.Column="3" Click="OnRemoveFolder" Content="− Remove"
                                                Background="#533483" Foreground="White"
                                                BorderThickness="0" Padding="10,4" FontSize="12"
                                                Cursor="Hand" />
                                    </Grid>
                                </Border>
                                <ListBox Grid.Row="1" x:Name="FolderList" MinHeight="60" MaxHeight="120"
                                         Background="{DynamicResource BgDarkBrush}" BorderThickness="0"
                                         Foreground="{DynamicResource TextPrimaryBrush}" FontSize="14"
                                         SelectionMode="Single" Margin="6,0,6,6" />
                            </Grid>
                        </Border>

                        <!-- ═══ METADATA TOGGLE ═══ -->
                        <Border Background="{DynamicResource BgSurfaceBrush}" CornerRadius="10"
                                Padding="14" Margin="0,0,0,14">
                            <CheckBox x:Name="EnableMetadataCb"
                                      Content="Fetch posters &amp; ratings from internet"
                                      Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13"
                                      Checked="OnMetadataCheckChanged" Unchecked="OnMetadataCheckChanged" />
                        </Border>

                        <!-- ═══ METADATA SOURCES ═══ -->
                        <Border x:Name="MetadataSection"
                                Background="{DynamicResource BgSurfaceBrush}" CornerRadius="10"
                                Padding="0" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}"
                                        Padding="14,10" CornerRadius="10,10,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="3" Height="18"
                                                   Fill="{DynamicResource AccentBrush}" RadiusX="1.5" RadiusY="1.5"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Metadata Sources"
                                                   FontWeight="Bold" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Button Grid.Column="2" Click="OnAddSourcePreset" Tag="OMDb" Content="+ OMDb"
                                                Background="#16213e" Foreground="White"
                                                BorderThickness="0" Padding="8,3" FontSize="11"
                                                Margin="0,0,4,0" Cursor="Hand" />
                                        <Button Grid.Column="3" Click="OnAddSourcePreset" Tag="TMDB" Content="+ TMDB"
                                                Background="#16213e" Foreground="White"
                                                BorderThickness="0" Padding="8,3" FontSize="11"
                                                Margin="0,0,4,0" Cursor="Hand" />
                                        <Button Grid.Column="4" Click="OnAddSourceCustom" Content="+ Custom"
                                                Style="{StaticResource AccentBtn}" Padding="8,3"
                                                FontSize="11" Margin="0,0,4,0" />
                                        <Button Grid.Column="5" Click="OnRemoveSource" Content="− Remove"
                                                Background="#533483" Foreground="White"
                                                BorderThickness="0" Padding="8,3" FontSize="11"
                                                Cursor="Hand" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="1" Padding="6,6,6,0">
                                    <Grid>
                                        <ListBox x:Name="SourceList" MinHeight="50" MaxHeight="90"
                                                 Background="{DynamicResource BgDarkBrush}"
                                                 BorderThickness="0"
                                                 Foreground="{DynamicResource TextPrimaryBrush}"
                                                 FontSize="13" SelectionMode="Single"
                                                 DisplayMemberPath="Display" />
                                        <TextBlock x:Name="NoSourcesLabel"
                                                   Text="No sources. Click + above to add one."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False" />
                                    </Grid>
                                </Border>

                                <Border Grid.Row="2" x:Name="SourceConfigPanel"
                                        Background="{DynamicResource BgCardBrush}"
                                        CornerRadius="8"
                                        Padding="12" Margin="6,6,6,6"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Name"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" Margin="0,0,4,4" />
                                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="SourceNameBox"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,4" />

                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="API Key"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" Margin="0,0,4,4" />
                                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="ApiKeyBox"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,4" />

                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="API URL"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" Margin="0,0,4,4" />
                                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="ApiUrlBox"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,4" />

                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Result Path"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" Margin="0,0,4,4" />
                                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="ResponsePathBox"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,4" />

                                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Poster URL"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="12" Margin="0,0,4,4" />
                                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="PosterBaseBox"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,4" />

                                            <Rectangle Grid.Row="5" Grid.ColumnSpan="2" Height="1"
                                                       Fill="{DynamicResource BgDarkBrush}"
                                                       Margin="0,0,0,6" />

                                            <TextBlock Grid.Row="6" Grid.Column="0" Text="↳ Title"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" Margin="0,0,4,2" />
                                            <TextBox Grid.Row="6" Grid.Column="1" x:Name="FieldTitle"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,2" />

                                            <TextBlock Grid.Row="7" Grid.Column="0" Text="↳ Year"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" Margin="0,0,4,2" />
                                            <TextBox Grid.Row="7" Grid.Column="1" x:Name="FieldYear"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,2" />

                                            <TextBlock Grid.Row="8" Grid.Column="0" Text="↳ Rating"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" Margin="0,0,4,2" />
                                            <TextBox Grid.Row="8" Grid.Column="1" x:Name="FieldRating"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,2" />

                                            <TextBlock Grid.Row="9" Grid.Column="0" Text="↳ Poster"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" Margin="0,0,4,2" />
                                            <TextBox Grid.Row="9" Grid.Column="1" x:Name="FieldPoster"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,2" />

                                            <TextBlock Grid.Row="10" Grid.Column="0" Text="↳ Plot"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="11" Margin="0,0,4,2" />
                                            <TextBox Grid.Row="10" Grid.Column="1" x:Name="FieldPlot"
                                                     Background="{DynamicResource BgSurfaceBrush}"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     BorderBrush="{DynamicResource BorderColorBrush}"
                                                     FontSize="12" Padding="4,2" Margin="0,0,0,2" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ═══ SUBTITLE FONT ═══ -->
                        <Border Background="{DynamicResource BgSurfaceBrush}" CornerRadius="10" Padding="0" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}"
                                        Padding="14,10" CornerRadius="10,10,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="3" Height="18"
                                                   Fill="{DynamicResource AccentBrush}" RadiusX="1.5" RadiusY="1.5"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Subtitle Font"
                                                   FontWeight="Bold" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}"
                                        CornerRadius="0,0,10,10" Padding="14" Margin="6,0,6,6">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Font:"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ComboBox Grid.Column="1" x:Name="SubtitleFontBox"
                                                  MinWidth="160" Margin="0,0,16,0">
                                            <ComboBoxItem Content="Arial" />
                                            <ComboBoxItem Content="Verdana" />
                                            <ComboBoxItem Content="Tahoma" />
                                            <ComboBoxItem Content="Times New Roman" />
                                            <ComboBoxItem Content="Courier New" />
                                            <ComboBoxItem Content="Segoe UI" />
                                            <ComboBoxItem Content="Consolas" />
                                        </ComboBox>
                                        <TextBlock Grid.Column="2" Text="Size:"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ComboBox Grid.Column="3" x:Name="SubtitleSizeBox" MinWidth="80">
                                            <ComboBoxItem Content="12" />
                                            <ComboBoxItem Content="16" />
                                            <ComboBoxItem Content="20" />
                                            <ComboBoxItem Content="24" />
                                            <ComboBoxItem Content="28" />
                                            <ComboBoxItem Content="36" />
                                            <ComboBoxItem Content="48" />
                                        </ComboBox>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- ═══ THUMBNAILS ═══ -->
                        <Border Background="{DynamicResource BgSurfaceBrush}" CornerRadius="10" Padding="0" Margin="0,0,0,14">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}"
                                        Padding="14,10" CornerRadius="10,10,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="3" Height="18"
                                                   Fill="{DynamicResource AccentBrush}" RadiusX="1.5" RadiusY="1.5"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Thumbnails"
                                                   FontWeight="Bold" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Padding="14,10" Background="{DynamicResource BgCardBrush}"
                                        CornerRadius="0,0,10,10" Margin="6,0,6,6">
                                    <StackPanel>
                                        <CheckBox x:Name="EnableThumbnailsCb" Content="Generate video thumbnails"
                                                  Foreground="{DynamicResource TextPrimaryBrush}" FontSize="13" />
                                        <Button x:Name="ClearThumbCacheBtn" Click="OnClearThumbnailCache"
                                                Content="🗑 Clear Thumbnail Cache"
                                                Background="#533483" Foreground="White"
                                                BorderThickness="0" Padding="10,4" FontSize="11"
                                                Cursor="Hand" Margin="0,8,0,0"
                                                HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- THEMES TAB -->
                <ScrollViewer Grid.Row="1" x:Name="ThemesContent"
                              VerticalScrollBarVisibility="Auto" Visibility="Collapsed" Margin="0,16,0,0">
                    <StackPanel>

                        <Border Background="{DynamicResource BgSurfaceBrush}" CornerRadius="10" Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}"
                                        Padding="14,10" CornerRadius="10,10,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Rectangle Grid.Column="0" Width="3" Height="18"
                                                   Fill="{DynamicResource AccentBrush}" RadiusX="1.5" RadiusY="1.5"
                                                   Margin="0,0,10,0" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="Color Theme"
                                                   FontWeight="Bold" FontSize="14"
                                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                                    </Grid>
                                </Border>
                                <Border Grid.Row="1" Background="{DynamicResource BgCardBrush}"
                                        CornerRadius="0,0,10,10" Padding="16" Margin="6,0,6,6">
                                    <StackPanel>
                                        <TextBlock Text="Choose a color scheme for the app interface."
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="13" Margin="0,0,0,14" />

                                        <RadioButton x:Name="ThemeDark" Content="🌙  Dark"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     FontSize="14" Margin="0,0,0,8"
                                                     Checked="OnThemeSelected" />
                                        <RadioButton x:Name="ThemeBlue" Content="🌊  Blue"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     FontSize="14" Margin="0,0,0,8"
                                                     Checked="OnThemeSelected" />
                                        <RadioButton x:Name="ThemeRed" Content="🔥  Red"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     FontSize="14" Margin="0,0,0,8"
                                                     Checked="OnThemeSelected" />
                                        <RadioButton x:Name="ThemeAmber" Content="🟠  Amber"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     FontSize="14" Margin="0,0,0,8"
                                                     Checked="OnThemeSelected" />
                                        <RadioButton x:Name="ThemeModern" Content="💠  Modern"
                                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                                     FontSize="14" Margin="0,0,0,8"
                                                     Checked="OnThemeSelected" />

                                        <!-- Theme preview -->
                                        <Border Background="{DynamicResource BgDarkBrush}" CornerRadius="8"
                                                Padding="14" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Row="0" Grid.Column="0"
                                                           Text="Preview text"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                           FontSize="13" VerticalAlignment="Center" />
                                                <Border Grid.Row="0" Grid.Column="1"
                                                        Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="4" Padding="10,3">
                                                    <TextBlock Text="Accent" Foreground="White"
                                                               FontSize="11" FontWeight="SemiBold" />
                                                </Border>
                                                <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                                           Text="Secondary text example"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" Margin="0,4,0,0" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>
        </Border>

        <!-- Bottom buttons -->
        <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}" Padding="24,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="OnSave" Content="Save &amp; Reload"
                        Style="{StaticResource AccentBtn}"
                        Padding="16,9" FontSize="13" Margin="0,0,10,0" />
                <Button Click="OnCancel" Content="Cancel"
                        Background="{DynamicResource BgCardBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderThickness="0" Padding="16,9" FontSize="13"
                        Cursor="Hand" />
            </StackPanel>
        </Border>
    </Grid>
</Window>